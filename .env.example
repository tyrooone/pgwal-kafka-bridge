# PostgreSQL
PG_URL="postgresql://replicator:secret@localhost:5432/mydb"
PG_SLOT_NAME="pgwal_bridge"
PG_PUB_NAME="pgwal_bridge_pub"

# Kafka
KAFKA_BROKERS="localhost:9092"
KAFKA_USERNAME="admin"
KAFKA_PASSWORD="secret"
KAFKA_BATCH_SIZE=100
KAFKA_BATCH_TIME=100

# Tables (JSON)
BRIDGE_TABLES='[{
  "schema": "public",
  "table": "orders",
  "targets": [{
    "topic": "orders-by-user",
    "partitionKey": "user_id"
  }, {
    "topic": "orders-by-region",
    "partitionKey": "region_id"
  }]
}]'
