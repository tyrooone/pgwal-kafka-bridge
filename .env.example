# PostgreSQL
PG_HOST="localhost"
PG_PORT="5432"
PG_DATABASE="mydb"
PG_USER="replicator"
PG_PASSWORD="secret"
PG_SLOT_NAME="pgwal_bridge"
PG_PUB_NAME="pgwal_bridge_pub"

# Kafka
KAFKA_CLIENT_ID="pgwal-bridge"
KAFKA_BROKERS="localhost:9092"
KAFKA_USERNAME="admin"
KAFKA_PASSWORD="secret"

# Tables (JSON)
BRIDGE_TABLES='[{
  "schema": "public",
  "table": "orders",
  "routes": [{
    "topic": "orders-by-user",
    "partitionKey": "user_id"
  }, {
    "topic": "orders-by-region",
    "partitionKey": "region_id"
  }]
}]'
